{
    "compilerOptions": {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "node",
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "jsx": "preserve",
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "resources/js/*"
            ]
        }
    },
    "include": [
        "resources/js/**/*",
        "resources/js/**/*.vue"
    ]
}